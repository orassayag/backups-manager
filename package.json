{
  "name": "backups-manager",
  "version": "1.0.0",
  "private": false,
  "description": "CLI tool for differential and full file backups across multiple paths by comparing source and target directories. Supports exclude patterns for files, folders, and paths, displays real-time progress and percentage indicators, and generates detailed reports of updated files into a log file.",
  "keywords": [
    "backup",
    "file-backup",
    "differential-backup",
    "incremental-backup",
    "sync",
    "file-sync",
    "directory-sync",
    "multi-path",
    "filesystem",
    "cli",
    "nodejs",
    "typescript",
    "progress-bar",
    "file-diff",
    "backup-tool",
    "automation",
    "exclude-patterns",
    "file-management",
    "recovery",
    "logging"
  ],
  "homepage": "https://github.com/orassayag/backups-manager#readme",
  "bugs": {
    "url": "https://github.com/orassayag/backups-manager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/orassayag/backups-manager.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/orassayag"
  },
  "license": "MIT",
  "author": {
    "name": "Or Assayag",
    "email": "orassayag@gmail.com",
    "url": "https://github.com/orassayag"
  },
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "type": "module",
  "main": "dist/index.js",
  "files": [
    ".cache",
    ".github",
    ".vscode",
    "dist",
    "logs",
    "misc",
    "src",
    ".gitignore",
    ".npmrc",
    ".prettierrc",
    "automatic-backup.bat",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "eslint.config.mjs",
    "INSTRUCTIONS.md",
    "knip.json",
    "LICENSE",
    "package.json",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml",
    "README.md",
    "SECURITY.md",
    "tsconfig.json",
    "tsconfig.node.json",
    "vitest.config.ts"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "start": "tsx src/index.ts",
    "sync": "tsx src/index.ts --auto --operation=diff",
    "test": "cross-env NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "test:no-coverage": "cross-env NODE_OPTIONS='--no-warnings' vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "cross-env NODE_OPTIONS='--no-warnings' vitest"
  },
  "dependencies": {
    "enquirer": "^2.4.1",
    "micromatch": "^4.0.8",
    "ora": "^9.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rolldown/binding-win32-x64-msvc": "^1.2.0",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
